rayBtn.TextColor3 = Color3.fromRGB(255,255,255)
rayBtn.BackgroundColor3 = Color3.fromRGB(8,8,8)
rayBtn.BackgroundTransparency = 0.08
rayBtn.Font = Enum.Font.GothamBlack
rayBtn.TextSize = 23
rayBtn.Active = true
rayBtn.Draggable = true
Instance.new("UICorner", rayBtn).CornerRadius = UDim.new(1,0)

local rayStroke = Instance.new("UIStroke", rayBtn)
rayStroke.Thickness = 2
rayStroke.Color = Color3.fromRGB(255,255,255)
rayStroke.Transparency = 0.2

rayBtn.MouseButton1Click:Connect(fakeReset)

